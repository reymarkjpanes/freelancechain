# ─── Stellar Network ────────────────────────────────────────────────────────
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# ─── Contract ────────────────────────────────────────────────────────────────
# The contract is already deployed on testnet. You can use this ID directly.
# If you need to redeploy, see DEPLOY.md for exact commands.
ESCROW_CONTRACT_ADDRESS=CAR33UWAUPQPFDSKUJK6WAVS33SA2EEES3ZXZKB7GXSNOS7YUQ6LZISS

# ─── Platform Ops Account ────────────────────────────────────────────────────
# These are the testnet ops account keys used for server-side job creation.
# To generate your own:
#   stellar keys generate ops --network testnet
#   stellar keys fund ops --network testnet
#   stellar keys address ops          → public key
#   stellar keys show ops --network testnet  → secret key
OPS_ACCOUNT_PUBLIC_KEY=GCOWPBOA5WNSBUBDNBY6M4XTN6OQPS5ITECIXFHKWLTVQCQ44NM7WY22
OPS_ACCOUNT_SECRET_KEY=SAEIUACBLW67G5RL5JHUTB5PSRDBPJ5L7RR3JUAUUSJQQG27ZD75K4JW   # ← NEVER commit real secrets

# ─── XLM Token (SEP-41 native wrapper) ───────────────────────────────────────
# Get the testnet native XLM SAC address with:
#   stellar contract id asset --network testnet --asset native
XLM_TOKEN_ADDRESS=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC

# ─── Platform Fee ────────────────────────────────────────────────────────────
PLATFORM_FEE_BASIS_POINTS=250
