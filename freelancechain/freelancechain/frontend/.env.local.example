# ─── Stellar Network ────────────────────────────────────────────────────────
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# ─── Contract ────────────────────────────────────────────────────────────────
# ⚠️  The old prototype (CBPXD4WLBHOQAX3YRI3Y55LE57ERDT57SLSBP32VFEQNL66PN7MAT26X)
#     has a DIFFERENT interface — you must redeploy the rewritten contract first.
#     See DEPLOY.md for exact commands.
ESCROW_CONTRACT_ADDRESS=REPLACE_WITH_NEW_CONTRACT_ID

# ─── Platform Ops Account ────────────────────────────────────────────────────
# Generate:  stellar keys generate ops --network testnet
# Fund:      stellar keys fund ops --network testnet
# Address:   stellar keys address ops
# Secret:    stellar keys show ops --network testnet
OPS_ACCOUNT_PUBLIC_KEY=REPLACE_WITH_OPS_PUBLIC_KEY
OPS_ACCOUNT_SECRET_KEY=REPLACE_WITH_OPS_SECRET_KEY   # ← NEVER commit this

# ─── XLM Token (SEP-41 native wrapper) ───────────────────────────────────────
# Get the testnet native XLM SAC address with:
#   stellar contract id asset --network testnet --asset native
XLM_TOKEN_ADDRESS=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC

# ─── Platform Fee ────────────────────────────────────────────────────────────
PLATFORM_FEE_BASIS_POINTS=250
